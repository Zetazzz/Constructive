{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../..",
    "baseUrl": "../..",
    "paths": {
      "@test/*": ["tools/test/*"],
      "agentic-kit": ["agentic-kit/src"],
      "@agentic-kit/agent": ["agent/src"],
      "@agentic-kit/protocol": ["protocol/src"]
    },
    "types": ["jest", "node"]
  },
  "include": [
    "./**/*.ts",
    "../src/**/*.ts",
    "../../tools/test/**/*.ts"
  ],
  "exclude": ["../dist", "../node_modules"]
}
