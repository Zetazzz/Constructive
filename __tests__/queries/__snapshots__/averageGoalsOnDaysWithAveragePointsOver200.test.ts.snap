exports[`AverageGoalsOnDaysWithAveragePointsOver200: sql 1`] = `
[
  "select __match_stats_result__.*
from (select 0 as idx, $1::"int4" as "id0") as __match_stats_identifiers__,
lateral (
  select
    (json_build_array(date_trunc('day', __match_stats__."created_at")))::text as "0",
    (avg(__match_stats__."goals"))::text as "1",
    __match_stats_identifiers__.idx as "2"
  from "test"."match_stats" as __match_stats__
  group by date_trunc('day', __match_stats__."created_at")
  having (
    ((avg(__match_stats__."points")) > __match_stats_identifiers__."id0")
  )
) as __match_stats_result__;",
]
`;
