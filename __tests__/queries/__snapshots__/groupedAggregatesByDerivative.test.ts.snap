exports[`GroupedAggregatesByDerivative: sql 1`] = `
[
  "select
  (avg(__match_stats__."points"))::text as "0",
  to_char(date_trunc('day', __match_stats__."created_at"), 'YYYY-MM-DD"T"HH24:MI:SS.USTZH:TZM'::text) as "1"
from "test"."match_stats" as __match_stats__
group by date_trunc('day', __match_stats__."created_at");",
