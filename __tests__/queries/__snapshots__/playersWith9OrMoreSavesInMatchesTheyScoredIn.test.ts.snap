exports[`PlayersWith9OrMoreSavesInMatchesTheyScoredIn: result 1`] = `
{
  "allPlayers": {
    "nodes": [
      {
        "matchStatsByPlayerId": {
          "aggregates": {
            "sum": {
              "goals": "28",
              "rating": 142,
              "saves": "10",
            },
          },
        },
        "name": "JutheKid",
      },
    ],
  },
}
`;

exports[`PlayersWith9OrMoreSavesInMatchesTheyScoredIn: sql 1`] = `
[
  "select __players_result__.*
from (select 0 as idx, $1::"int4" as "id0", $2::"int8" as "id1", $3::"float8" as "id2", $4::"int4" as "id3") as __players_identifiers__,
lateral (
  select
    __players__."name" as "0",
    (select json_agg(s) from (
      select
        (coalesce(sum(__match_stats__."saves"), '0'))::text as "0",
        (coalesce(sum("test"."match_stats_rating"(__match_stats__)), '0'))::text as "1",
        (coalesce(sum(__match_stats__."goals"), '0'))::text as "2"
      from "test"."match_stats" as __match_stats__
      where
        (
          __match_stats__."goals" > __players_identifiers__."id3"
        ) and (
          __players__."id"::"int4" = __match_stats__."player_id"
        )
    ) s) as "1",
    __players_identifiers__.idx as "2"
  from "test"."players" as __players__
  where (
      (
        select (
          (coalesce(sum(__match_stats_2."saves"), '0') > __players_identifiers__."id1")
        and
          (coalesce(sum("test"."match_stats_rating"(__match_stats_2)), '0') < __players_identifiers__."id2")
        )
        from "test"."match_stats" as __match_stats_2
        where (
          (__players__."id" = __match_stats_2."player_id")
        and
          (
            __match_stats_2."goals" > __players_identifiers__."id0"
          )
        )
      group by ())
  )
  order by __players__."id" asc
) as __players_result__;",
]
`;
