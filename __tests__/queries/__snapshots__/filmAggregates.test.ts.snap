exports[`calculates film aggregates: queries 1`] = `
[
  "select __films_result__.*
from (select 0 as idx, $1::"int4" as "id0") as __films_identifiers__,
lateral (
  select
    (count(distinct __films__."id"))::text as "0",
    (count(distinct __films__."name"))::text as "1",
    (count(distinct __films__."year_of_release"))::text as "2",
    (count(distinct "test"."films_computed_column"(__films__)))::text as "3",
    (coalesce(sum("test"."films_computed_column"(__films__)), '0'))::text as "4",
    (coalesce(sum("test"."films_computed_column_with_arguments"(
      __films__,
      __films_identifiers__."id0"
    )), '0'))::text as "5",
    (coalesce(sum(__films__."year_of_release"), '0'))::text as "6",
    (coalesce(sum(__films__."box_office_in_billions"), '0'))::text as "7",
    __films_identifiers__.idx as "8"
  from "test"."films" as __films__
) as __films_result__;",
]
`;

