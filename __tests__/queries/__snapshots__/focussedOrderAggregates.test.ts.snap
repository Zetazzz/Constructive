exports[`FocussedOrderedAggregate: sql 1`] = `
[
  "select
  __players__."name" as "0",
  array(
    select array[
      (count(*))::text,
      (coalesce(sum(__match_stats__."goals"), '0'))::text,
      (avg(__match_stats__."points"))::text
    ]::text[]
    from "test"."match_stats" as __match_stats__
    where (
      __match_stats__."player_id" = __players__."id"
    )
  )::text as "1"
from "test"."players" as __players__
order by (
  select avg(__match_stats_2."points")
  from "test"."match_stats" __match_stats_2
  where (__match_stats_2."player_id" = __players__."id")
) desc, __players__."id" asc
limit 5;",
]
`;
