exports[`GameAggregates: sql 1`] = `
[
  "select
  (max(__match_stats__."points"))::text as "0",
  (max(__match_stats__."goals"))::text as "1",
  (max(__match_stats__."saves"))::text as "2",
  (min(__match_stats__."points"))::text as "3"
from "test"."match_stats" as __match_stats__;",
  "/* UNSUPPORTED QUERY CALL! */",
  "select
  __players__."name" as "0",
  (select json_agg(s) from (
    select
      (count(*))::text as "0",
      (coalesce(sum(__match_stats__."points"), '0'))::text as "1",
      (coalesce(sum(__match_stats__."goals"), '0'))::text as "2",
      (coalesce(sum(__match_stats__."saves"), '0'))::text as "3",
      (avg(__match_stats__."points"))::text as "4",
      (avg(__match_stats__."goals"))::text as "5",
      (avg(__match_stats__."saves"))::text as "6",
      (avg(__match_stats__."team_position"))::text as "7"
    from "test"."match_stats" as __match_stats__
    where (
      __players__."id"::"int4" = __match_stats__."player_id"
    )
  ) s) as "1"
from "test"."players" as __players__
order by (
  select coalesce(sum(__match_stats_2."goals"), '0')
  from "test"."match_stats" __match_stats_2
  where (__match_stats_2."player_id" = __players__."id")
) asc, __players__."id" asc;",
]
`;
