  """
  some: ViewMatchStatFilter

  """
  No related \`ViewMatchStat\` matches the filter criteria. All fields are combined with a logical ‘and.’
  """
  none: ViewMatchStatFilter

  """Aggregates across related \`ViewMatchStat\` match the filter criteria."""
