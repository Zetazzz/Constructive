"""
A filter to be used against many \`MatchStat\` object types. All fields are combined with a logical ‘and.’
"""
input PlayerToManyMatchStatFilter {
  """
  Every related \`MatchStat\` matches the filter criteria. All fields are combined with a logical ‘and.’
  """
  every: MatchStatFilter

  """
  Some related \`MatchStat\` matches the filter criteria. All fields are combined with a logical ‘and.’
  """
  some: MatchStatFilter

  """
  No related \`MatchStat\` matches the filter criteria. All fields are combined with a logical ‘and.’
  """
  none: MatchStatFilter

  """Aggregates across related \`MatchStat\` match the filter criteria."""
  aggregates: MatchStatAggregatesFilter
}

"""
A filter to be used against many \`ViewMatchStat\` object types. All fields are combined with a logical ‘and.’
