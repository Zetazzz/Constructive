"""The root query type which gives access points into the data universe."""
type Query implements Node {
  """
  Exposes the root query type nested one level down. This is helpful for Relay 1
  which can only query top level fields if they are in a particular form.
  """
  query: Query!

  """
  The root query type must be a \`Node\` to work well with Relay 1 mutations. This just resolves to \`query\`.
  """
  id: ID!

  """Fetches an object given its globally unique \`ID\`."""
  node(
    """The globally unique \`ID\`."""
    id: ID!
  ): Node

  """Get a single \`Match\`."""
  matchByRowId(rowId: Int!): Match

  """Get a single \`Player\`."""
  playerByRowId(rowId: Int!): Player

  """Get a single \`Film\`."""
  filmByRowId(rowId: Int!): Film

  """Get a single \`MatchStat\`."""
  matchStatByRowId(rowId: Int!): MatchStat

  """Reads a single \`Match\` using its globally unique \`ID\`."""
  match(
    """The globally unique \`ID\` to be used in selecting a single \`Match\`."""
    id: ID!
  ): Match

  """Reads a single \`Player\` using its globally unique \`ID\`."""
  player(
    """The globally unique \`ID\` to be used in selecting a single \`Player\`."""
    id: ID!
  ): Player

  """Reads a single \`Film\` using its globally unique \`ID\`."""
  film(
    """The globally unique \`ID\` to be used in selecting a single \`Film\`."""
    id: ID!
  ): Film

  """Reads a single \`MatchStat\` using its globally unique \`ID\`."""
  matchStat(
    """The globally unique \`ID\` to be used in selecting a single \`MatchStat\`."""
    id: ID!
  ): MatchStat

  """Reads and enables pagination through a set of \`Match\`."""
  allMatches(
    """Only read the first \`n\` values of the set."""
    first: Int

    """Only read the last \`n\` values of the set."""
    last: Int

    """
    Skip the first \`n\` values from our \`after\` cursor, an alternative to cursor
    based pagination. May not be used with \`last\`.
    """
    offset: Int

    """Read all values in the set before (above) this cursor."""
    before: Cursor

    """Read all values in the set after (below) this cursor."""
    after: Cursor

    """The method to use when ordering \`Match\`."""
    orderBy: [MatchOrderBy!] = [PRIMARY_KEY_ASC]

    """
    A condition to be used in determining which values should be returned by the collection.
    """
    condition: MatchCondition

    """
    A filter to be used in determining which values should be returned by the collection.
    """
    filter: MatchFilter
  ): MatchConnection

  """Reads and enables pagination through a set of \`Player\`."""
  allPlayers(
    """Only read the first \`n\` values of the set."""
    first: Int

    """Only read the last \`n\` values of the set."""
    last: Int

    """
    Skip the first \`n\` values from our \`after\` cursor, an alternative to cursor
    based pagination. May not be used with \`last\`.
    """
    offset: Int

    """Read all values in the set before (above) this cursor."""
    before: Cursor

    """Read all values in the set after (below) this cursor."""
    after: Cursor

    """The method to use when ordering \`Player\`."""
    orderBy: [PlayerOrderBy!] = [PRIMARY_KEY_ASC]

    """
    A condition to be used in determining which values should be returned by the collection.
    """
    condition: PlayerCondition

    """
    A filter to be used in determining which values should be returned by the collection.
    """
    filter: PlayerFilter
  ): PlayerConnection

  """Reads and enables pagination through a set of \`Film\`."""
  allFilms(
    """Only read the first \`n\` values of the set."""
    first: Int

    """Only read the last \`n\` values of the set."""
    last: Int

    """
    Skip the first \`n\` values from our \`after\` cursor, an alternative to cursor
    based pagination. May not be used with \`last\`.
    """
    offset: Int

    """Read all values in the set before (above) this cursor."""
    before: Cursor

    """Read all values in the set after (below) this cursor."""
    after: Cursor

    """The method to use when ordering \`Film\`."""
    orderBy: [FilmOrderBy!] = [PRIMARY_KEY_ASC]

    """
    A condition to be used in determining which values should be returned by the collection.
    """
    condition: FilmCondition

    """
    A filter to be used in determining which values should be returned by the collection.
    """
    filter: FilmFilter
  ): FilmConnection

  """Reads and enables pagination through a set of \`ViewMatchStat\`."""
  allViewMatchStats(
    """Only read the first \`n\` values of the set."""
    first: Int

    """Only read the last \`n\` values of the set."""
    last: Int

