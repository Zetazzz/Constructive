{
  "name": "agentic-kit",
  "version": "1.0.3",
  "author": "Dan Lynch <pyramation@gmail.com>",
  "description": "Provider-agnostic LLM adapter with streaming and multi-turn support",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./index.js"
    }
  },
  "homepage": "https://github.com/constructive-io/agentic-kit",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/agentic-kit"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/agentic-kit/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "postbuild": "node ../../scripts/write-esm-package-json.js",
    "build:dev": "makage build --dev",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@agentic-kit/anthropic": "workspace:*",
    "@agentic-kit/ollama": "workspace:*",
    "@agentic-kit/openai": "workspace:*"
  },
  "keywords": []
}
